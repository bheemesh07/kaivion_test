{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["*.css", "*.js", "*.svg", "*.png", "*.ico"]
  },
  "responseOverrides": {
    "404": { "rewrite": "/index.html", "statusCode": 200 }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Cache-Control": "public, max-age=86400"
  }
}
